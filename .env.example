# Contexlia frontend environment
# Copy to .env.local for local development. Only NEXT_PUBLIC_* values are exposed to the browser.

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Tenant IDs
# NEXT_PUBLIC_COMMUNITY_TENANT is the personal workspace tenant UUID.
NEXT_PUBLIC_COMMUNITY_TENANT=
# Legacy compatibility key for the default shared/public tenant UUID.
NEXT_PUBLIC_KIDNEY_TENANT=

# Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Maps and location features
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Social integrations
NEXT_PUBLIC_INSTAGRAM_CLIENT_ID=

# Bulk import helpers
NEXT_PUBLIC_GOOGLE_SHEETS_TEMPLATE_ID=

# Optional tutorial content
NEXT_PUBLIC_GETTING_STARTED_COLLECTION_ID=

# PubMed / NCBI metadata
NEXT_PUBLIC_NCBI_TOOL=contexlia
NEXT_PUBLIC_NCBI_EMAIL=contact@example.com
